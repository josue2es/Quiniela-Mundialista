# Quiniela Mundialista — Environment Variables
# Copy to .env and fill in values

# App storage secret key (set a strong random string)
STORAGE_SECRET=change-me-to-a-random-string

# Database path (SQLite)
DB_PATH=/data/quiniela.db

# Path to players CSV (en Docker, montá tu CSV en ./data/config/players.csv)
PLAYERS_CSV=/config/players.csv

# Cargar datos de demostración (dieciseisavos) si la BD está vacía.
# 1/true para activar; ideal para probar sin API key ni players.csv.
SEED_DEMO=0

# Match data provider
MATCH_PROVIDER=api_football
APIFOOTBALL_KEY=

# Timezone
TZ=America/El_Salvador

# Balldontlie API key (fallback provider for match data)
BALLDONTLIE_API_KEY=
